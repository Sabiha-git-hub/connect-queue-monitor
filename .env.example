# Amazon Connect Workshop App - Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control (it contains secrets!)

# ============================================
# AWS Configuration
# ============================================

# Your AWS region where Amazon Connect is running
# Example: us-east-1, us-west-2, eu-west-1
AWS_REGION=us-east-1

# Optional: AWS credentials (only needed if not using IAM roles)
# Leave blank if using AWS CLI configured credentials or EC2 instance roles
# AWS_ACCESS_KEY_ID=your-access-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-key-here

# ============================================
# Amazon Connect Configuration
# ============================================

# Your Amazon Connect instance ID (UUID format)
# Find this in Amazon Connect console under "Instance ARN"
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CONNECT_INSTANCE_ID=6091de37-993e-45c8-9637-e9e3a0af5b23

# Your Amazon Connect instance URL (for Streams API)
# Format: https://your-instance-name.my.connect.aws
CONNECT_INSTANCE_URL=https://unt-sample-cicd-instance-sab-test.my.connect.aws

# ============================================
# Application Configuration
# ============================================

# Flask secret key for session management (generate a random string)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=8f2e9a7c4b6d1f3e5a8c2b9d4f7e1a6c3b8f5d2e9a7c4b1f6e3d8a5c2b9f7e4a1c6d3b8f2e5a9c7b4d1f6e8a3c5b2f9d7e4a1c6b8f3d5e2a9c7b4f1e6d8a3c5b2f9e7d4a1c6b8f3e5a2d9c7b4f1e6a8c3d5b2f9e7a4c1b6d8f3e5a2c9b7d4f1e6a8c3b5d2f9e7a4c1b6d8f3e5a2c9b7d4f1e6a8


# Enable debug mode for development (set to False in production)
FLASK_DEBUG=True

# ============================================
# Iframe Embedding Configuration
# ============================================

# Comma-separated list of allowed origins for CORS and iframe embedding
# Include your Amazon Connect instance domains
# Example: https://your-instance.my.connect.aws,https://your-instance.awsapps.com
ALLOWED_ORIGINS=https://unt-sample-cicd-instance-sab-test.my.connect.aws,https://unt-sample-cicd-instance-sab-test.awsapps.com
